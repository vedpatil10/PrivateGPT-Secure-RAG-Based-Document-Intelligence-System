# ===== Application =====
APP_NAME=PrivateGPT
APP_ENV=development
DEBUG=true

# ===== Security =====
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENCRYPTION_KEY=your-fernet-encryption-key

# ===== LLM Configuration =====
# Supported providers: llama_cpp, ollama, huggingface
LLM_PROVIDER=llama_cpp
# Path to GGUF model file (download separately)
LLM_MODEL_PATH=./models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
LLM_CONTEXT_LENGTH=2048
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_N_THREADS=4
# GPU layers (0 for CPU-only)
LLM_N_GPU_LAYERS=0

# ===== Embedding Configuration =====
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=./data/cache/embeddings

# ===== Retrieval Configuration =====
RETRIEVAL_TOP_K=20
RETRIEVAL_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_RERANKING=true

# ===== Chunking Configuration =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
ENABLE_HIERARCHICAL_CHUNKING=true
SUMMARY_MAX_LENGTH=500

# ===== Database =====
DATABASE_URL=sqlite+aiosqlite:///./data/privategpt.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://privategpt:privategpt@localhost:5432/privategpt
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===== Background Processing =====
INGESTION_POLL_INTERVAL_SECONDS=2.0
RECOVER_STALE_DOCUMENTS_ON_STARTUP=true

# ===== Storage =====
UPLOAD_DIR=./data/uploads
FAISS_INDEX_DIR=./data/faiss_indexes
CACHE_DIR=./data/cache

# ===== Ollama (if using Ollama provider) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# ===== HuggingFace (if using HuggingFace provider) =====
HF_MODEL_ID=TinyLlama/TinyLlama-1.1B-Chat-v1.0
HF_AUTH_TOKEN=
HF_DEVICE_MAP=auto
HF_LOAD_IN_4BIT=false
HF_LOAD_IN_8BIT=false
HF_TRUST_REMOTE_CODE=false
